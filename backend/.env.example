# Copy to .env for local development. Never commit the real .env.

ENVIRONMENT=dev

# Database (async driver). Local default matches docker-compose / local Postgres.
DATABASE_URL=postgresql+asyncpg://plantreviver:plantreviver@localhost:5432/plantreviver

# Connection pool (see ARCHITECTURE.md — per-process pool)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Auth
JWT_SECRET=dev-insecure-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=2592000
APPLE_BUNDLE_ID=com.example.plantreviver

# Premium integrations (optional until those features are built)
ANTHROPIC_API_KEY=
OPENWEATHER_API_KEY=

# Object storage (Cloudflare R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
